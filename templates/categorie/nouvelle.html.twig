{% extends 'base.html.twig' %}

{% block title %}Nouvelle Catégorie{% endblock %}

{% block body %}

<div class="container mt-4">

<h2>Créer catégorie</h2>

{{ form_start(form) }}

<div class="mb-3">
{{ form_row(form.nom) }}
</div>

<div class="mb-3">
{{ form_row(form.description) }}
</div>

<button class="btn btn-success">
Enregistrer
</button>

{{ form_end(form) }}

</div>

{% endblock %}