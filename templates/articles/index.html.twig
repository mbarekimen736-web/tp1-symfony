{% extends 'base.html.twig' %}

{% block title %}Liste des catégories{% endblock %}

{% block body %}
<h1>Liste des catégories</h1>

<table class="table table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nom</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        {% for categorie in categories %}
        <tr>
            <td>{{ categorie.id }}</td>
            <td>{{ categorie.nom }}</td>
            <td>
                <a href="#" class="btn btn-warning btn-sm">✏ Modifier</a>
                <form method="post" action="#" style="display:inline-block;" onsubmit="return confirm('Supprimer cette catégorie ?');">
                    <button class="btn btn-danger btn-sm">❌ Supprimer</button>
                </form>
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="3">Aucune catégorie trouvée</td>
        </tr>
        {% endfor %}
    </tbody>
</table>

<a href="{{ path('app_categorie_nouvelle') }}" class="btn btn-primary">📝 Créer une catégorie</a>
{% endblock %}


